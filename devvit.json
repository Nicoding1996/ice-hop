{
  "name": "ice-hop",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Post today's puzzle",
        "description": "Manually create the daily puzzle post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-daily"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "daily-puzzle": {
        "endpoint": "/internal/scheduler/daily-puzzle",
        "cron": "0 12 * * *"
      },
      "endless-refill": {
        "endpoint": "/internal/scheduler/endless-refill",
        "cron": "*/5 * * * *"
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "ice_hop_dev"
  }
}